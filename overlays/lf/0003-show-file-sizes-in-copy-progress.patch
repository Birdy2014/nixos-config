From c516c58f180e094d8878351f5a12b3bfeabc12a7 Mon Sep 17 00:00:00 2001
From: Moritz Vogel <moritzv7@gmail.com>
Date: Wed, 3 Dec 2025 15:35:41 +0100
Subject: [PATCH 3/3] show file sizes in copy progress

---
 ui.go | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/ui.go b/ui.go
index ebbe88a..0fcd8ad 100644
--- a/ui.go
+++ b/ui.go
@@ -937,7 +937,7 @@ func (ui *ui) drawRuler(nav *nav) {
 		if nav.copyTotal == 0 {
 			progress = append(progress, fmt.Sprintf("[0%%]"))
 		} else {
-			progress = append(progress, fmt.Sprintf("[%d%%]", nav.copyBytes*100/nav.copyTotal))
+			progress = append(progress, fmt.Sprintf("[%s/%s - %d%%]", humanize(uint64(nav.copyBytes)), humanize(uint64(nav.copyTotal)), nav.copyBytes*100/nav.copyTotal))
 		}
 	}
 
